# ── Core ──────────────────────────────────────────────────────────────────────
DOMAIN=app.veritas-infra.com
ENVIRONMENT=production

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=veritas
POSTGRES_USER=veritas
POSTGRES_PASSWORD=REPLACE_POSTGRES_PASSWORD

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=REPLACE_JWT_SECRET
FIRST_SUPERUSER_EMAIL=admin@veritas-infra.com
FIRST_SUPERUSER_PASSWORD=REPLACE_ADMIN_PASSWORD

# ── Network ───────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://app.veritas-infra.com,https://www.veritas-infra.com
TRUSTED_HOSTS=app.veritas-infra.com,www.veritas-infra.com

# ── MinIO (object storage) ────────────────────────────────────────────────────
MINIO_ROOT_USER=REPLACE_MINIO_USER
MINIO_ROOT_PASSWORD=REPLACE_MINIO_PASSWORD
MINIO_BUCKET_EVIDENCE=veritas-evidence

# ── Observability ─────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=REPLACE_GRAFANA_PASSWORD

# ── SEAL service ──────────────────────────────────────────────────────────────
SEAL_REGISTRY_URL=https://app.veritas-infra.com/verify

# ── Workers ───────────────────────────────────────────────────────────────────
UVICORN_WORKERS=2
CELERY_CONCURRENCY=2
CELERY_LOGLEVEL=info
CELERY_QUEUES=celery
